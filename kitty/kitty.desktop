# Copy this kitty.desktop file to ~/.local/share/applications/

[Desktop Entry]
Name=Kitty Terminal
Comment=Powerful, customizable, and fast terminal emulator
Exec=/home/luis/.local/kitty.app/bin/kitty
Icon=/home/luis/.config/kitty/kitty-icon.png
Terminal=false
Type=Application
Categories=System;TerminalEmulator;
