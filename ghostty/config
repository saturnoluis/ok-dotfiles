# Ghostty Configuration
# Migrated from Kitty configuration

# Colors - Adwaita Dark Theme
# For light theme, manually edit these colors or create a separate config
background = #000000
foreground = #deddda
selection-background = #1c1c1c
selection-foreground = #c0bfbc
cursor-color = #deddda
cursor-text = #000000

# ANSI Colors (0-15)
palette = 0=#000000
palette = 1=#ed333b
palette = 2=#57e389
palette = 3=#ff7800
palette = 4=#62a0ea
palette = 5=#9141ac
palette = 6=#5bc8af
palette = 7=#deddda
palette = 8=#9a9996
palette = 9=#f66151
palette = 10=#8ff0a4
palette = 11=#ffa348
palette = 12=#99c1f1
palette = 13=#dc8add
palette = 14=#93ddc2
palette = 15=#f6f5f4

# Transparency (no blur)
background-opacity = 0.8

# Window Settings
window-decoration = auto
gtk-titlebar = false
maximize = true

# Font Settings
font-family = FiraCode Nerd Font Mono
font-size = 14

# Bell - Visual only (border, no audio/system sounds)
bell-features = border,no-audio,no-system

# Keybindings (matching Kitty configuration)
keybind = ctrl+shift+f=toggle_fullscreen
keybind = ctrl+shift+l=next_tab
keybind = ctrl+shift+h=previous_tab
keybind = ctrl+shift+,=prompt_tab_title

# Additional common keybindings
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface

# Mouse Settings
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
copy-on-select = true

# Clipboard Settings
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true

# Shell Integration
shell-integration = detect
